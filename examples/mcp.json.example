{
  "servers": {
    "telegram-copilot-bridge": {
      "command": "python",
      "args": ["-m", "telegram_copilot_bridge"],
      "env": {
        "TELEGRAM_BOT_TOKEN": "<your-bot-token>",
        "TELEGRAM_CHAT_ID": "<your-chat-id>",
        "TELEGRAM_ALLOWED_USERS": "<your-user-id>"
      }
    }
  }
}
