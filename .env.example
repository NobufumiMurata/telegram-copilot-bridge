# telegram-copilot-bridge configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments. Quotes are optional.

# ─── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TELEGRAM_CHAT_ID=-100000000000
TELEGRAM_ALLOWED_USERS=123456789

# ─── Path to this .env file (optional – for non-default locations) ────────────
# TELEGRAM_ENV_FILE=/path/to/.env

# ─── JSON credential file fallback ───────────────────────────────────────────
# TELEGRAM_CONFIG_PATH=secrets/telegram-bot.json

# ─── Copilot Hub settings ─────────────────────────────────────────────────────
# COPILOT_CLI_PATH=copilot
# COPILOT_MODEL=claude-opus-4.6
# COPILOT_AUTOPILOT=false

# Root directory shown in /dirs and /new folder picker
# COPILOT_DIRS_ROOT=/home/user/projects

# Comma-separated list of directories Copilot sessions are allowed to use
# COPILOT_ALLOWED_DIRS=/home/user/projects,/tmp

# Comma-separated list of tools Copilot CLI may use
# COPILOT_ALLOWED_TOOLS=shell(git),read,write,edit,create

# Permission approval timeout in seconds (default: 300 = 5 min)
# COPILOT_PERMISSION_TIMEOUT_SECONDS=300

# Hub auto-shutdown timeout in minutes (0 or unset = no timeout)
# HUB_TIMEOUT_MINUTES=0

# TCP port used for Hub singleton lock (default: 47732)
# HUB_LOCK_PORT=47732
